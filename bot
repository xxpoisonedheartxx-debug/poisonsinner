import discord
from discord.ext import commands, tasks
import os
import requests
from ics import Calendar
from datetime import datetime, timedelta, timezone
from dotenv import load_dotenv

load_dotenv()

# ---------------- CONFIG ----------------

TOKEN = os.getenv("DISCORD_TOKEN")
ICS_URL = os.getenv("ICS_URL")

ANNOUNCE_CHANNEL_ID = int(os.getenv("ANNOUNCE_CHANNEL_ID"))
FLYER_CHANNEL_ID = int(os.getenv("FLYER_CHANNEL_ID"))

intents = discord.Intents.default()
intents.message_content = True

bot = commands.Bot(command_prefix="!", intents=intents)

# ---------------- STORAGE ----------------

flyers = {}          # flyer_id -> image_url
sent_reminders = set()

calendar_cache = None
last_fetch = None


# ---------------- CALENDAR LOADER (CACHED) ----------------

def load_calendar():
    global calendar_cache, last_fetch

    now = datetime.now(timezone.utc)

    # cache for 60 seconds
    if last_fetch and (now - last_fetch).seconds < 60:
        return calendar_cache

    try:
        data = requests.get(ICS_URL, timeout=10).text
        calendar_cache = Calendar(data)
        last_fetch = now
        return calendar_cache

    except Exception as e:
        print("ICS fetch error:", e)
        return None


# ---------------- FLYER SYSTEM ----------------

@bot.event
async def on_message(message):

    if message.channel.id != FLYER_CHANNEL_ID:
        return

    if not message.attachments:
        return

    flyer_id = message.content.strip().lower()

    if not flyer_id:
        return

    flyers[flyer_id] = message.attachments[0].url

    await message.channel.send(
        f"✅ Flyer `{flyer_id}` saved."
    )


# ---------------- EVENT CHECK LOOP ----------------

@tasks.loop(minutes=1)
async def check_events():

    calendar = load_calendar()
    if not calendar:
        return

    now = datetime.now(timezone.utc)

    for event in calendar.events:

        if not event.begin:
            continue

        start = event.begin.datetime

        # FIX: timezone safety
        if start.tzinfo is None:
            start = start.replace(tzinfo=timezone.utc)
        else:
            start = start.astimezone(timezone.utc)

        reminder_time = start - timedelta(minutes=5)

        event_key = f"{event.uid}-5min"

        if event_key in sent_reminders:
            continue

        if now >= reminder_time and now <= reminder_time + timedelta(minutes=1):

            title = event.name or "Event"
            description = event.description or ""

            flyer_id = None
            ping_role = None

            # parse calendar description
            for line in description.splitlines():

                if line.startswith("FLYER="):
                    flyer_id = line.replace("FLYER=", "").strip().lower()

                if line.startswith("PING="):
                    ping_role = line.replace("PING=", "").strip()

            embed = discord.Embed(
                title=f"⏰ {title}",
                description="Starts in 5 minutes!",
                color=discord.Color.red()
            )

            # attach flyer image
            if flyer_id and flyer_id in flyers:
                embed.set_image(url=flyers[flyer_id])

            channel = bot.get_channel(ANNOUNCE_CHANNEL_ID)

            content = f"@{ping_role}" if ping_role else "@everyone"

            await channel.send(content=content, embed=embed)

            sent_reminders.add(event_key)

            print(f"Sent reminder: {title}")


# ---------------- START BOT ----------------

@bot.event
async def on_ready():
    print(f"Logged in as {bot.user}")
    check_events.start()


bot.run(TOKEN)
